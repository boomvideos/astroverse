# ═══════════════════════════════════════════════════════
# AstroVerse AI — Environment Variables
# ═══════════════════════════════════════════════════════
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your values
# 3. NEVER commit .env to git

# ── Anthropic API Key ──────────────────────────────────
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Server Port ────────────────────────────────────────
PORT=3001

# ── Allowed CORS Origin ────────────────────────────────
# Development:  * (allow all)
# Production:   https://yourdomain.com  ← always set a specific domain in production
ALLOWED_ORIGIN=*

# ── MongoDB (required for chart save/retrieve) ─────────
# Get a free cluster at: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://<user>:<password>@cluster0.mongodb.net/astroverse
MONGODB_URI=

# ── Clerk Authentication ───────────────────────────────
# Backend secret key — get from https://dashboard.clerk.com
# Settings → API Keys → Secret keys
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here

# ── Frontend (Vite) ────────────────────────────────────
# These are read by Vite at build time — prefix with VITE_
# Publishable key — get from https://dashboard.clerk.com
# Settings → API Keys → Publishable key
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here

# Backend API base URL (leave empty to use relative paths via Vite proxy)
VITE_API_BASE=

# App URL (used in SEO meta tags)
VITE_APP_URL=http://localhost:5173
